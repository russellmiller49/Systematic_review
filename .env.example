# Copy to .env for local development (docker-compose defaults).
DATABASE_URL="postgresql://srb:srb@localhost:5442/srb_dev"
TEST_DATABASE_URL="postgresql://srb:srb@localhost:5442/srb_test"

# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-me"
AUTH_TRUST_HOST="true"

# Local file storage root (FileStorage LocalDiskStorage driver)
STORAGE_DIR="./storage"

# Optional pilot gate. When set, only these comma-separated emails or people with an active
# project invitation may create accounts. Leave blank for open registration.
PILOT_EMAIL_ALLOWLIST=""

# AI features (prescreening + extraction suggestions).
# Leave the selected provider's key empty to disable all AI UI and endpoints.
AI_PROVIDER="anthropic"      # anthropic | openai | gemini
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
GEMINI_API_KEY=""
# Optional model overrides (defaults: anthropic=claude-opus-4-8, openai=gpt-5.1, gemini=gemini-2.5-pro)
AI_SCREENING_MODEL=""
AI_EXTRACTION_MODEL=""

# Contact email sent to external scholarly APIs (Unpaywall requires it as a query param;
# also used in the Crossref/Europe PMC User-Agent). Leave blank to disable the Unpaywall
# open-access lookup — Europe PMC still works without it.
CONTACT_EMAIL=""
