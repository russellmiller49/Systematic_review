// Synthesis — systematic review & meta-analysis platform
// Data-model rationale: docs/02-data-model.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

enum ProjectRole {
  OWNER
  ADMIN
  REVIEWER
  ADJUDICATOR
  EXTRACTOR
  STATISTICIAN
  LIBRARIAN
  PANEL_MEMBER
  TRAINEE
  OBSERVER
}

enum MemberStatus {
  ACTIVE
  REMOVED
}

enum ReviewType {
  SYSTEMATIC_REVIEW
  SYSTEMATIC_REVIEW_META_ANALYSIS
  DIAGNOSTIC_TEST_ACCURACY
  SCOPING_REVIEW
  RAPID_REVIEW
  LIVING_SYSTEMATIC_REVIEW
  GUIDELINE_EVIDENCE_REVIEW
}

enum ProjectStatus {
  PLANNING
  SCREENING
  EXTRACTION
  ANALYSIS
  COMPLETED
  ARCHIVED
}

enum CriterionType {
  INCLUSION
  EXCLUSION
}

enum OutcomeType {
  PRIMARY
  SECONDARY
}

enum ImportFormat {
  RIS
  BIBTEX
  CSV
  NBIB
}

enum ImportBatchStatus {
  PREVIEWED
  COMMITTED
  FAILED
}

enum CitationStatus {
  ACTIVE
  DUPLICATE
}

enum IdentifierType {
  DOI
  PMID
  PMCID
  URL
  ISBN
  REGISTRY_ID
  OTHER
}

enum DedupMethod {
  EXACT_DOI
  EXACT_PMID
  NORMALIZED_TITLE
  FUZZY
}

enum DedupCandidateStatus {
  SUGGESTED
  MERGED
  REJECTED
}

enum DedupGroupStatus {
  OPEN
  RESOLVED
}

enum StageType {
  TITLE_ABSTRACT
  FULL_TEXT
}

enum AssignmentStatus {
  PENDING
  COMPLETED
  VOIDED // e.g. citation merged as duplicate after assignment
}

// How a citation's per-stage outcome was reached (see CitationStageResult).
enum ResolutionVia {
  CONSENSUS
  ADJUDICATION
  SINGLE_REVIEWER
}

enum Decision {
  INCLUDE
  EXCLUDE
  MAYBE
  UNRESOLVED
}

enum ConflictStatus {
  OPEN
  RESOLVED
  VOIDED // citation merged as duplicate / result reopened
}

enum ReasonStage {
  TITLE_ABSTRACT
  FULL_TEXT
  BOTH
}

enum RetrievalOutcome {
  PENDING
  RETRIEVED
  NOT_RETRIEVED
}

enum TemplateStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum FieldType {
  TEXT
  TEXTAREA
  NUMBER
  DATE
  SINGLE_SELECT
  MULTI_SELECT
  BOOLEAN
}

enum FormStatus {
  IN_PROGRESS
  COMPLETED
}

// NOTE: RoB judgments are Strings validated against RiskOfBiasTool.judgmentScale (per-tool
// scales: RoB2 uses low/some concerns/high, NOS uses stars, etc.). No closed enum.

enum ExportKind {
  CITATIONS
  SCREENING
  EXTRACTION
  ROB
  PRISMA
  AUDIT
  FULL
  ANALYSIS // per-outcome study effects + pooled results (phase B)
  GRADE // summary of findings + per-domain certainty ratings (phase C)
}

enum ExportFormat {
  CSV
  JSON
}

enum ExportStatus {
  PENDING
  COMPLETED
  FAILED
}

enum AiRunStatus {
  PENDING // run row created; provider not yet acknowledged
  SUBMITTED // provider batch accepted (batch runs only; sync extraction skips it)
  COMPLETED
  FAILED
  CANCELED
}

// --- Analysis (meta-analysis module) ---------------------------------------

enum EffectMeasure {
  RR // risk ratio (binary 2x2, log scale)
  OR // odds ratio (binary 2x2, log scale)
  RD // risk difference (binary 2x2, linear scale)
  MD // mean difference (continuous, linear scale)
  SMD // standardized mean difference, Hedges g (continuous, linear scale)
  PROPORTION // single-arm proportion (phase B)
  GENERIC_IV // pre-computed estimate + SE (phase B)
}

enum PoolingModel {
  FIXED
  RANDOM
}

enum ProportionTransform {
  LOGIT
  FREEMAN_TUKEY
}

enum EffectDirection {
  HIGHER_IS_BETTER
  LOWER_IS_BETTER
}

// Statistical role an extraction field plays for an outcome. G1 = intervention/exposure
// group, G2 = comparator. Which roles a measure requires is service-enforced.
enum AnalysisRole {
  G1_EVENTS
  G1_TOTAL
  G2_EVENTS
  G2_TOTAL
  G1_MEAN
  G1_SD
  G1_N
  G2_MEAN
  G2_SD
  G2_N
  EFFECT_ESTIMATE // phase B (GENERIC_IV)
  EFFECT_SE // phase B
  EFFECT_CI_LOW // phase B
  EFFECT_CI_UP // phase B
  STUDY_DESIGN // phase C (GRADE starting-certainty hint; SINGLE_SELECT field)
}

// ---------------------------------------------------------------------------
// Users & teams
// ---------------------------------------------------------------------------

model User {
  id                String    @id @default(cuid())
  email             String    @unique // stored lowercased (service-enforced)
  name              String
  passwordHash      String
  passwordChangedAt DateTime? // JWTs issued before this are invalid (checked in jwt callback)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  orgMemberships          OrganizationMember[]
  projectMemberships      ProjectMember[]
  createdOrgs             Organization[]             @relation("OrgCreator")
  createdProjects         Project[]                  @relation("ProjectCreator")
  sentInvitations         ProjectInvitation[]        @relation("InvitationSender")
  sentOrgInvitations      OrganizationInvitation[]   @relation("OrganizationInvitationSender")
  protocolVersions        ProtocolVersion[]          @relation("ProtocolVersionAuthor")
  protocolAmendments      ProtocolAmendment[]        @relation("AmendmentAuthor")
  importBatches           ImportBatch[]              @relation("ImportCreator")
  dedupDecisions          DeduplicationCandidate[]   @relation("DedupDecider")
  createdStudies          Study[]                    @relation("StudyCreator")
  screeningAssignments    ScreeningAssignment[]      @relation("AssignmentReviewer")
  screeningDecisions      ScreeningDecision[]        @relation("DecisionReviewer")
  adjudications           ScreeningAdjudication[]    @relation("Adjudicator")
  uploadedFiles           FullTextFile[]             @relation("FileUploader")
  retrievalAttempts       FullTextRetrievalAttempt[] @relation("RetrievalRecorder")
  extractionTemplates     ExtractionTemplate[]       @relation("TemplateCreator")
  extractionAssignments   ExtractionAssignment[]     @relation("ExtractionAssignee")
  extractionForms         ExtractionForm[]           @relation("Extractor")
  extractionAdjudications ExtractionAdjudication[]   @relation("ExtractionAdjudicator")
  robTools                RiskOfBiasTool[]           @relation("RobToolCreator")
  robAssignments          RiskOfBiasAssignment[]     @relation("RobAssignee")
  robAssessments          RiskOfBiasAssessment[]     @relation("RobAssessor")
  robAdjudications        RiskOfBiasAdjudication[]   @relation("RobAdjudicator")
  prismaSnapshots         PrismaSnapshot[]           @relation("SnapshotCreator")
  exportJobs              ExportJob[]                @relation("ExportRequester")
  auditEvents             AuditEvent[]               @relation("AuditActor")
  aiScreeningRuns         AiScreeningRun[]           @relation("AiScreeningRunRequester")
  aiExtractionRuns        AiExtractionRun[]          @relation("AiExtractionRunRequester")
  aiRobRuns               AiRobRun[]                 @relation("AiRobRunRequester")
  analysisOutcomes        AnalysisOutcome[]          @relation("AnalysisOutcomeCreator")
  analysisExclusions      AnalysisStudyExclusion[]   @relation("AnalysisExclusionCreator")
  cohortDecisions         CohortCandidate[]          @relation("CohortDecider")
  gradeAssessments        GradeAssessment[]          @relation("GradeAssessmentCreator")
  gradeReviews            GradeAssessment[]          @relation("GradeReviewer")
  gradeRatingEdits        GradeDomainRating[]        @relation("GradeRatingEditor")
  aiGradeRuns             AiGradeRun[]               @relation("AiGradeRunRequester")
  notifications           Notification[]             @relation("NotificationRecipient")
  notificationsActed      Notification[]             @relation("NotificationActor")
  librarySettingsUpdates  OrganizationLibrarySettings[] @relation("LibrarySettingsUpdater")
  fullTextRetrievalRuns   FullTextRetrievalRun[]     @relation("FullTextRetrievalRunRequester")
  referenceEntries        ReferenceEntry[]           @relation("ReferenceAdder")
  manuscriptsCreated      Manuscript[]               @relation("ManuscriptCreator")
  manuscriptAssignments   ManuscriptSection[]        @relation("ManuscriptSectionAssignee")
  manuscriptLocks         ManuscriptSection[]        @relation("ManuscriptSectionLockHolder")
  manuscriptVersions      ManuscriptSectionVersion[] @relation("ManuscriptVersionAuthor")
  manuscriptComments      ManuscriptComment[]        @relation("ManuscriptCommentAuthor")
  manuscriptResolved      ManuscriptComment[]        @relation("ManuscriptCommentResolver")
  chatChannelsCreated     ChatChannel[]              @relation("ChatChannelCreator")
  chatParticipations      ChatChannelParticipant[]   @relation("ChatParticipant")
  chatMessages            ChatMessage[]              @relation("ChatMessageAuthor")
  chatMessagesDeleted     ChatMessage[]              @relation("ChatMessageDeleter")
  chatAssignmentTasks     ChatAssignmentTask[]       @relation("ChatAssignee")
  chatReadStates          ChatReadState[]            @relation("ChatReader")
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy       User                         @relation("OrgCreator", fields: [createdById], references: [id])
  members         OrganizationMember[]
  invitations     OrganizationInvitation[]
  projects        Project[]
  librarySettings OrganizationLibrarySettings?
}

model OrganizationMember {
  id        String       @id @default(cuid())
  orgId     String
  userId    String
  role      OrgRole
  status    MemberStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  org  Organization @relation(fields: [orgId], references: [id])
  user User         @relation(fields: [userId], references: [id])

  @@unique([orgId, userId])
}

model OrganizationInvitation {
  id          String    @id @default(cuid())
  orgId       String
  email       String // lowercased
  role        OrgRole
  token       String    @unique // crypto.randomBytes(32) base64url; returned only at creation
  invitedById String
  expiresAt   DateTime
  acceptedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  organization Organization @relation(fields: [orgId], references: [id])
  invitedBy    User         @relation("OrganizationInvitationSender", fields: [invitedById], references: [id])

  @@index([orgId])
  @@index([email])
}

// Institutional library access (docs/09 posture: links out through the member's own
// browser session — the app never stores institutional credentials). Upserted 1:1 by
// org OWNER/ADMIN; consumed read-only by the full-text queue to build library links.
model OrganizationLibrarySettings {
  id              String   @id @default(cuid())
  orgId           String   @unique
  institutionName String? // "Find via <name>" button label
  ezproxyBaseUrl  String? // https-only prefix, e.g. https://login.ezproxy.myuni.edu/login?url=
  openUrlBaseUrl  String? // https-only Z39.88 OpenURL resolver base
  updatedById     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  org       Organization @relation(fields: [orgId], references: [id])
  updatedBy User         @relation("LibrarySettingsUpdater", fields: [updatedById], references: [id])
}

model Project {
  id                   String        @id @default(cuid())
  orgId                String
  title                String
  reviewType           ReviewType
  researchQuestion     String?
  description          String?
  status               ProjectStatus @default(PLANNING)
  registrationPlatform String? // e.g. PROSPERO
  registrationId       String?
  createdById          String
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  org       Organization @relation(fields: [orgId], references: [id])
  createdBy User         @relation("ProjectCreator", fields: [createdById], references: [id])

  members             ProjectMember[]
  invitations         ProjectInvitation[]
  protocol            Protocol?
  exclusionReasons    ExclusionReason[]
  importSources       ImportSource[]
  importBatches       ImportBatch[]
  citations           Citation[]
  dedupGroups         DeduplicationGroup[]
  dedupCandidates     DeduplicationCandidate[]
  studies             Study[]
  screeningStages     ScreeningStage[]
  fullTextFiles       FullTextFile[]
  extractionTemplates ExtractionTemplate[]
  robTools            RiskOfBiasTool[]
  prismaSnapshots     PrismaSnapshot[]
  exportJobs          ExportJob[]
  auditEvents         AuditEvent[]
  aiScreeningRuns     AiScreeningRun[]
  aiExtractionRuns    AiExtractionRun[]
  aiRobRuns           AiRobRun[]
  aiGradeRuns         AiGradeRun[]
  analysisOutcomes    AnalysisOutcome[]
  cohortCandidates    CohortCandidate[]
  notifications       Notification[]
  fullTextRetrievalRuns FullTextRetrievalRun[]
  referenceEntries    ReferenceEntry[]
  manuscript          Manuscript?
  chatChannels        ChatChannel[]
  chatAssignmentTasks ChatAssignmentTask[]

  @@index([orgId])
}

model ProjectMember {
  id        String        @id @default(cuid())
  projectId String
  userId    String
  roles     ProjectRole[]
  status    MemberStatus  @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  project Project @relation(fields: [projectId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
  @@index([userId])
}

model ProjectInvitation {
  id          String        @id @default(cuid())
  projectId   String
  email       String // lowercased
  roles       ProjectRole[]
  token       String        @unique // crypto.randomBytes(32) base64url; returned only at creation
  invitedById String
  expiresAt   DateTime
  acceptedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime      @default(now())

  project   Project @relation(fields: [projectId], references: [id])
  invitedBy User    @relation("InvitationSender", fields: [invitedById], references: [id])

  @@index([projectId])
  @@index([email])
}

// ---------------------------------------------------------------------------
// Protocol
// ---------------------------------------------------------------------------

model Protocol {
  id                      String   @id @default(cuid())
  projectId               String   @unique
  background              String?
  reviewQuestion          String?
  population              String?
  intervention            String? // intervention / index test / exposure
  comparator              String? // comparator / reference standard
  outcomesNarrative       String?
  studyDesigns            String[]
  setting                 String?
  dateRestrictionFrom     Int? // publication year lower bound
  dateRestrictionTo       Int?
  languageRestrictions    String[]
  databases               String[] // planned databases to search
  grayLiteratureSources   String[]
  searchStrategyNotes     String?
  subgroupAnalysisPlan    String?
  sensitivityAnalysisPlan String?
  metaAnalysisPlan        String?
  gradePlan               String?
  extractionTemplateId    String?  @unique // planned extraction form (spec: ExtractionFieldDefinition)
  riskOfBiasToolId        String? // planned RoB tool (spec: RiskOfBiasToolConfig)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  project            Project             @relation(fields: [projectId], references: [id])
  extractionTemplate ExtractionTemplate? @relation(fields: [extractionTemplateId], references: [id])
  riskOfBiasTool     RiskOfBiasTool?     @relation(fields: [riskOfBiasToolId], references: [id])

  picoQuestions PICOQuestion[]
  criteria      EligibilityCriterion[]
  outcomes      OutcomeDefinition[]
  versions      ProtocolVersion[]
  amendments    ProtocolAmendment[]
}

model PICOQuestion {
  id           String   @id @default(cuid())
  protocolId   String
  order        Int      @default(0)
  question     String
  population   String?
  intervention String?
  comparator   String?
  outcome      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  protocol Protocol @relation(fields: [protocolId], references: [id])

  @@index([protocolId])
}

model EligibilityCriterion {
  id         String        @id @default(cuid())
  protocolId String
  type       CriterionType // INCLUSION | EXCLUSION (spec: InclusionCriterion / ExclusionCriterion)
  category   String? // population, intervention, design, setting, ...
  text       String
  order      Int           @default(0)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  protocol Protocol @relation(fields: [protocolId], references: [id])

  @@index([protocolId, type])
}

model OutcomeDefinition {
  id         String      @id @default(cuid())
  protocolId String
  name       String
  type       OutcomeType @default(PRIMARY)
  measure    String? // e.g. RR, MD, proportion — future meta-analysis/GRADE anchor
  timepoint  String?
  order      Int         @default(0)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  protocol         Protocol          @relation(fields: [protocolId], references: [id])
  analysisOutcomes AnalysisOutcome[]

  @@index([protocolId])
}

// Immutable full snapshot of protocol + children at publish/amendment time.
model ProtocolVersion {
  id            String   @id @default(cuid())
  protocolId    String
  versionNumber Int
  snapshot      Json
  createdById   String
  createdAt     DateTime @default(now())

  protocol  Protocol @relation(fields: [protocolId], references: [id])
  createdBy User     @relation("ProtocolVersionAuthor", fields: [createdById], references: [id])

  @@unique([protocolId, versionNumber])
}

model ProtocolAmendment {
  id          String   @id @default(cuid())
  protocolId  String
  fromVersion Int
  toVersion   Int
  reason      String // required — why the protocol changed after screening began
  description String?
  createdById String
  createdAt   DateTime @default(now())

  protocol  Protocol @relation(fields: [protocolId], references: [id])
  createdBy User     @relation("AmendmentAuthor", fields: [createdById], references: [id])

  @@index([protocolId])
}

// Project-scoped exclusion reasons (protocol-derived; FULL_TEXT exclusions must cite one).
model ExclusionReason {
  id        String      @id @default(cuid())
  projectId String
  label     String
  stage     ReasonStage @default(BOTH)
  order     Int         @default(0)
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  project       Project                 @relation(fields: [projectId], references: [id])
  decisions     ScreeningDecision[]
  adjudications ScreeningAdjudication[]

  @@unique([projectId, label])
}

// ---------------------------------------------------------------------------
// Imports & citations
// ---------------------------------------------------------------------------

model ImportSource {
  id          String   @id @default(cuid())
  projectId   String
  name        String // "PubMed", "Embase", "Hand search", ...
  description String?
  createdAt   DateTime @default(now())

  project Project       @relation(fields: [projectId], references: [id])
  batches ImportBatch[]

  @@unique([projectId, name])
}

model ImportBatch {
  id            String            @id @default(cuid())
  projectId     String
  sourceId      String
  filename      String
  format        ImportFormat
  status        ImportBatchStatus @default(PREVIEWED)
  totalRecords  Int               @default(0)
  parsedRecords Int               @default(0)
  failedRecords Int               @default(0)
  committedAt   DateTime?
  createdById   String
  createdAt     DateTime          @default(now())

  project       Project                @relation(fields: [projectId], references: [id])
  source        ImportSource           @relation(fields: [sourceId], references: [id])
  createdBy     User                   @relation("ImportCreator", fields: [createdById], references: [id])
  sourceRecords CitationSourceRecord[]

  @@index([projectId])
}

// The report (article/abstract/registry entry). Never hard-deleted; dedup flips status.
model Citation {
  id              String         @id @default(cuid())
  projectId       String
  status          CitationStatus @default(ACTIVE)
  duplicateOfId   String? // set when merged as duplicate of the canonical citation
  title           String
  normalizedTitle String // service-maintained, for exact-title dedup
  authors         Json // [{ family, given, raw }]
  year            Int?
  journal         String?
  volume          String?
  issue           String?
  pages           String?
  abstract        String?
  doi             String? // normalized lowercase, no https://doi.org/
  pmid            String?
  url             String?
  language        String?
  affiliations    Json? // string[] — record-level bag from AD/SI/C1 import tags (cohort detection)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  project     Project    @relation(fields: [projectId], references: [id])
  duplicateOf Citation?  @relation("DuplicateOf", fields: [duplicateOfId], references: [id])
  duplicates  Citation[] @relation("DuplicateOf")

  sourceRecords       CitationSourceRecord[]
  identifiers         CitationIdentifier[]
  studyLinks          StudyReportLink[]
  assignments         ScreeningAssignment[]
  decisions           ScreeningDecision[]
  conflicts           ScreeningConflict[]
  stageResults        CitationStageResult[]
  fullTextLinks       CitationFullTextLink[]
  retrievalAttempts   FullTextRetrievalAttempt[]
  extractionForms     ExtractionForm[]
  aiSuggestions       ScreeningSuggestion[]
  dedupCandidatesAsA  DeduplicationCandidate[]   @relation("DedupCitationA")
  dedupCandidatesAsB  DeduplicationCandidate[]   @relation("DedupCitationB")
  cohortCandidatesAsA CohortCandidate[]          @relation("CohortCitationA")
  cohortCandidatesAsB CohortCandidate[]          @relation("CohortCitationB")
  referenceEntries    ReferenceEntry[]

  @@index([projectId, status])
  @@index([projectId, normalizedTitle])
  @@index([projectId, doi])
  @@index([projectId, pmid])
}

// Immutable raw import record. Created at preview (citationId null), linked at commit.
model CitationSourceRecord {
  id          String   @id @default(cuid())
  batchId     String
  citationId  String?
  rowNumber   Int
  rawRecord   String // verbatim source chunk (RIS block, BibTeX entry, CSV row)
  parsed      Json? // parser output
  parseErrors Json? // row-level errors (record preserved even when unparseable)
  createdAt   DateTime @default(now())

  batch    ImportBatch @relation(fields: [batchId], references: [id])
  citation Citation?   @relation(fields: [citationId], references: [id])

  @@index([batchId])
  @@index([citationId])
}

model CitationIdentifier {
  id         String         @id @default(cuid())
  citationId String
  type       IdentifierType
  value      String

  citation Citation @relation(fields: [citationId], references: [id])

  @@unique([citationId, type, value])
  @@index([type, value])
}

// ---------------------------------------------------------------------------
// Deduplication
// ---------------------------------------------------------------------------

model DeduplicationGroup {
  id        String           @id @default(cuid())
  projectId String
  status    DedupGroupStatus @default(OPEN)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  project    Project                  @relation(fields: [projectId], references: [id])
  candidates DeduplicationCandidate[]

  @@index([projectId, status])
}

// A suggested duplicate PAIR with the evidence for why it was suggested.
model DeduplicationCandidate {
  id          String               @id @default(cuid())
  projectId   String
  groupId     String?
  citationAId String // invariant (service-enforced): citationAId < citationBId
  citationBId String
  method      DedupMethod
  score       Float // 1.0 for exact methods
  reasons     Json // human-readable evidence: matched fields, similarity values
  status      DedupCandidateStatus @default(SUGGESTED)
  decidedById String?
  decidedAt   DateTime?
  createdAt   DateTime             @default(now())

  project   Project             @relation(fields: [projectId], references: [id])
  group     DeduplicationGroup? @relation(fields: [groupId], references: [id])
  citationA Citation            @relation("DedupCitationA", fields: [citationAId], references: [id])
  citationB Citation            @relation("DedupCitationB", fields: [citationBId], references: [id])
  decidedBy User?               @relation("DedupDecider", fields: [decidedById], references: [id])

  @@unique([citationAId, citationBId])
  @@index([citationBId])
  @@index([projectId, status])
}

// ---------------------------------------------------------------------------
// Cohort-overlap detection (companion reports of the same underlying cohort)
// ---------------------------------------------------------------------------

enum CohortMethod {
  REGISTRY_ID // tier 1: shared trial-registry identifier
  COMPOSITE // tier 2: author/affiliation/title/year composite score
}

enum CohortCandidateStatus {
  SUGGESTED
  LINKED
  REJECTED
}

// Pairs CITATIONS (not studies) — study membership is recomputed live at decision
// time. citationAId < citationBId is service-enforced for pair identity.
model CohortCandidate {
  id          String                @id @default(cuid())
  projectId   String
  citationAId String
  citationBId String
  method      CohortMethod
  score       Float
  signals     Json // { registryIds?, authorOverlap?, affiliationSimilarity?, titleTokens?, yearDelta?, acronyms? }
  status      CohortCandidateStatus @default(SUGGESTED)
  decidedById String?
  decidedAt   DateTime?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  project   Project  @relation(fields: [projectId], references: [id])
  citationA Citation @relation("CohortCitationA", fields: [citationAId], references: [id])
  citationB Citation @relation("CohortCitationB", fields: [citationBId], references: [id])
  decidedBy User?    @relation("CohortDecider", fields: [decidedById], references: [id])

  @@unique([projectId, citationAId, citationBId])
  @@index([projectId, status])
  @@index([citationBId])
}

// ---------------------------------------------------------------------------
// Studies (the analysis unit; multiple citations/reports may link to one study)
// ---------------------------------------------------------------------------

model Study {
  id                      String   @id @default(cuid())
  projectId               String
  label                   String // e.g. "Smith 2019"
  notes                   String?
  // PRISMA: all studies count toward qualitative synthesis; this flag adds the
  // "included in quantitative synthesis (meta-analysis)" count.
  inQuantitativeSynthesis Boolean  @default(false)
  createdById             String
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  project   Project @relation(fields: [projectId], references: [id])
  createdBy User    @relation("StudyCreator", fields: [createdById], references: [id])

  reportLinks           StudyReportLink[]
  extractionAssignments ExtractionAssignment[]
  extractionForms       ExtractionForm[]
  extractionConflicts   ExtractionConflict[]
  robAssignments        RiskOfBiasAssignment[]
  robAssessments        RiskOfBiasAssessment[]
  robConflicts          RiskOfBiasConflict[]
  aiExtractionRuns      AiExtractionRun[]
  aiSuggestions         ExtractionSuggestion[]
  aiRobRuns             AiRobRun[]
  robSuggestions        RobSuggestion[]
  analysisExclusions    AnalysisStudyExclusion[]

  @@index([projectId])
}

// One report may in principle inform multiple studies (cohort overlap); the MVP service
// enforces one study per report as a soft default, not a DB constraint.
model StudyReportLink {
  id              String  @id @default(cuid())
  studyId         String
  citationId      String
  isPrimaryReport Boolean @default(false)

  study    Study    @relation(fields: [studyId], references: [id])
  citation Citation @relation(fields: [citationId], references: [id])

  @@unique([studyId, citationId])
  @@index([citationId])
}

// ---------------------------------------------------------------------------
// Screening
// ---------------------------------------------------------------------------

model ScreeningStage {
  id                     String    @id @default(cuid())
  projectId              String
  type                   StageType
  reviewersPerCitation   Int       @default(2)
  blinded                Boolean   @default(true)
  maybeGeneratesConflict Boolean   @default(true)
  unblindedAt            DateTime? // admin unblind action (audited)
  // AI prescreening display settings (see ScreeningSuggestion). Audited methodology
  // toggles via updateStage; aiShowScores is inert until suggestions exist.
  aiShowScores           Boolean   @default(true) // surface score badges in the queue payload
  aiRankingEnabled       Boolean   @default(false) // order the queue by score desc, nulls last
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  project       Project               @relation(fields: [projectId], references: [id])
  assignments   ScreeningAssignment[]
  decisions     ScreeningDecision[]
  conflicts     ScreeningConflict[]
  stageResults  CitationStageResult[]
  aiRuns        AiScreeningRun[]
  aiSuggestions ScreeningSuggestion[]

  @@unique([projectId, type])
}

// Materialized per-citation stage outcome — THE definition of stage progression.
// Written in the same transaction as the last required decision (consensus) or the
// adjudication that resolves a conflict. "Advanced to full text" = INCLUDE result at the
// TITLE_ABSTRACT stage. PRISMA counts derive from these rows. Reopening (admin/adjudicator)
// deletes the row, voids the conflict resolution, and is audited.
model CitationStageResult {
  id          String        @id @default(cuid())
  stageId     String
  citationId  String
  outcome     Decision // INCLUDE | EXCLUDE (MAYBE/UNRESOLVED never materialize)
  resolvedVia ResolutionVia
  resolvedAt  DateTime      @default(now())

  stage    ScreeningStage @relation(fields: [stageId], references: [id])
  citation Citation       @relation(fields: [citationId], references: [id])

  @@unique([stageId, citationId])
  @@index([stageId, outcome])
}

model ScreeningAssignment {
  id         String           @id @default(cuid())
  stageId    String
  citationId String
  reviewerId String
  status     AssignmentStatus @default(PENDING)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  stage    ScreeningStage @relation(fields: [stageId], references: [id])
  citation Citation       @relation(fields: [citationId], references: [id])
  reviewer User           @relation("AssignmentReviewer", fields: [reviewerId], references: [id])

  @@unique([stageId, citationId, reviewerId])
  @@index([reviewerId, status])
  @@index([stageId, citationId])
}

// One reviewer's current decision. Updated in place; every change is audited with previousValue.
model ScreeningDecision {
  id                   String   @id @default(cuid())
  stageId              String
  citationId           String
  reviewerId           String
  decision             Decision
  exclusionReasonId    String? // REQUIRED (service-enforced) for FULL_TEXT + EXCLUDE
  notes                String?
  labels               String[]
  flaggedForDiscussion Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  stage           ScreeningStage   @relation(fields: [stageId], references: [id])
  citation        Citation         @relation(fields: [citationId], references: [id])
  reviewer        User             @relation("DecisionReviewer", fields: [reviewerId], references: [id])
  exclusionReason ExclusionReason? @relation(fields: [exclusionReasonId], references: [id])

  @@unique([stageId, citationId, reviewerId])
  @@index([stageId, decision])
  @@index([citationId])
}

model ScreeningConflict {
  id         String         @id @default(cuid())
  stageId    String
  citationId String
  status     ConflictStatus @default(OPEN)
  openedAt   DateTime       @default(now())
  resolvedAt DateTime?

  stage        ScreeningStage         @relation(fields: [stageId], references: [id])
  citation     Citation               @relation(fields: [citationId], references: [id])
  adjudication ScreeningAdjudication?

  @@unique([stageId, citationId])
  @@index([stageId, status])
}

model ScreeningAdjudication {
  id                String   @id @default(cuid())
  conflictId        String   @unique
  adjudicatorId     String // always from session — rule 5
  finalDecision     Decision
  exclusionReasonId String?
  reason            String // required rationale
  createdAt         DateTime @default(now())

  conflict        ScreeningConflict @relation(fields: [conflictId], references: [id])
  adjudicator     User              @relation("Adjudicator", fields: [adjudicatorId], references: [id])
  exclusionReason ExclusionReason?  @relation(fields: [exclusionReasonId], references: [id])
}

// ---------------------------------------------------------------------------
// Full text
// ---------------------------------------------------------------------------

// Server-side text-layer extraction state for a stored PDF (anchor v2 substrate).
enum TextLayerStatus {
  PENDING // never extracted
  EXTRACTED // FullTextPage rows exist for every page
  NO_TEXT_LAYER // scanned/image-only PDF (< 50 chars/page) — page-level anchors only
  FAILED // extraction errored; retryable
}

model FullTextFile {
  id           String   @id @default(cuid())
  projectId    String
  storageKey   String   @unique
  filename     String
  contentType  String
  sizeBytes    Int
  sha256       String
  uploadedById String
  createdAt    DateTime @default(now())

  // Anchor v2 text layer: pages are extracted server-side (once per textVersion) so
  // char offsets in stored anchors refer to OUR text, never a pdf.js version's output.
  textStatus  TextLayerStatus @default(PENDING)
  pageCount   Int?
  textVersion Int             @default(0) // bumped on every (re-)extraction

  project          Project                @relation(fields: [projectId], references: [id])
  uploadedBy       User                   @relation("FileUploader", fields: [uploadedById], references: [id])
  links            CitationFullTextLink[]
  aiExtractionRuns AiExtractionRun[]
  aiRobRuns        AiRobRun[]
  pages            FullTextPage[]

  @@index([projectId])
  @@index([sha256])
}

// One extracted text page of a FullTextFile (normalized upstream of storage is NOT
// applied — this is the raw pdf.js text so quote matching can normalize consistently).
model FullTextPage {
  id     String @id @default(cuid())
  fileId String
  page   Int // 1-based
  text   String

  file FullTextFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@unique([fileId, page])
}

model CitationFullTextLink {
  id         String   @id @default(cuid())
  citationId String
  fileId     String
  label      String? // "main paper", "supplement", ...
  createdAt  DateTime @default(now())

  citation Citation     @relation(fields: [citationId], references: [id])
  file     FullTextFile @relation(fields: [fileId], references: [id])

  @@unique([citationId, fileId])
}

model FullTextRetrievalAttempt {
  id           String           @id @default(cuid())
  citationId   String
  method       String // publisher site, library, ILL, author email, ...
  outcome      RetrievalOutcome
  notes        String?
  recordedById String
  attemptedAt  DateTime         @default(now())

  citation   Citation @relation(fields: [citationId], references: [id])
  recordedBy User     @relation("RetrievalRecorder", fields: [recordedById], references: [id])

  @@index([citationId])
}

// Open-access auto-fetch runs (Unpaywall + Europe PMC). No background worker exists —
// a run advances only while a client polls (same lifecycle as AiScreeningRun), so status
// starts at RUNNING (there is no provider handoff step).
enum RetrievalRunStatus {
  RUNNING
  COMPLETED
  FAILED
  CANCELED
}

model FullTextRetrievalRun {
  id             String             @id @default(cuid())
  projectId      String
  status         RetrievalRunStatus @default(RUNNING)
  citationIds    Json // snapshot of eligible citation ids at start, in processing order
  totalCount     Int                @default(0)
  claimedCount   Int                @default(0) // chunk-claim cursor (concurrent-poll guard)
  processedCount Int                @default(0)
  retrievedCount Int                @default(0)
  error          String?
  requestedById  String
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  completedAt    DateTime?

  project     Project @relation(fields: [projectId], references: [id])
  requestedBy User    @relation("FullTextRetrievalRunRequester", fields: [requestedById], references: [id])

  @@index([projectId, status])
  @@index([projectId, createdAt(sort: Desc)])
}

// ---------------------------------------------------------------------------
// Extraction
// ---------------------------------------------------------------------------

// Versioning: PUBLISHED templates are structurally immutable. A "new version" is a new row
// cloned from sourceTemplateId with version+1; the old row is ARCHIVED. Forms keep pointing
// at the exact version they were extracted with.
model ExtractionTemplate {
  id               String         @id @default(cuid())
  projectId        String
  name             String
  description      String?
  status           TemplateStatus @default(DRAFT)
  version          Int            @default(1)
  sourceTemplateId String? // lineage: the version this one was cloned from
  createdById      String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  project          Project              @relation(fields: [projectId], references: [id])
  createdBy        User                 @relation("TemplateCreator", fields: [createdById], references: [id])
  sourceTemplate   ExtractionTemplate?  @relation("TemplateLineage", fields: [sourceTemplateId], references: [id])
  derivedTemplates ExtractionTemplate[] @relation("TemplateLineage")

  fields           ExtractionField[]
  assignments      ExtractionAssignment[]
  forms            ExtractionForm[]
  conflicts        ExtractionConflict[]
  protocol         Protocol?
  aiRuns           AiExtractionRun[]
  aiSuggestions    ExtractionSuggestion[]
  analysisMappings AnalysisFieldMap[]

  @@index([projectId])
}

model ExtractionField {
  id         String    @id @default(cuid())
  templateId String
  key        String // machine name, stable across label edits
  label      String
  type       FieldType
  section    String?
  helpText   String?
  required   Boolean   @default(false)
  options    Json? // for selects: [{value, label}]
  order      Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  template      ExtractionTemplate     @relation(fields: [templateId], references: [id])
  values        ExtractionValue[]
  conflicts     ExtractionConflict[]
  aiSuggestions ExtractionSuggestion[]

  @@unique([templateId, key])
  @@index([templateId, order])
}

model ExtractionAssignment {
  id          String           @id @default(cuid())
  templateId  String
  studyId     String
  extractorId String
  status      AssignmentStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  template  ExtractionTemplate @relation(fields: [templateId], references: [id])
  study     Study              @relation(fields: [studyId], references: [id])
  extractor User               @relation("ExtractionAssignee", fields: [extractorId], references: [id])

  @@unique([templateId, studyId, extractorId])
  @@index([extractorId, status])
}

model ExtractionForm {
  id          String     @id @default(cuid())
  templateId  String
  studyId     String
  citationId  String? // optional report-level anchor
  extractorId String
  status      FormStatus @default(IN_PROGRESS)
  completedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  template  ExtractionTemplate @relation(fields: [templateId], references: [id])
  study     Study              @relation(fields: [studyId], references: [id])
  citation  Citation?          @relation(fields: [citationId], references: [id])
  extractor User               @relation("Extractor", fields: [extractorId], references: [id])
  values    ExtractionValue[]

  @@unique([templateId, studyId, extractorId])
  @@index([studyId])
}

model ExtractionValue {
  id           String   @id @default(cuid())
  formId       String
  fieldId      String
  value        Json // typed by field.type, validated in service
  sourceQuote  String?
  pageNumber   Int?
  notes        String?
  sourceAnchor Json? // future AI anchoring: { fileId, page, bbox | paragraphPath | tableCell }
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  form  ExtractionForm  @relation(fields: [formId], references: [id])
  field ExtractionField @relation(fields: [fieldId], references: [id])

  @@unique([formId, fieldId])
}

model ExtractionConflict {
  id         String         @id @default(cuid())
  templateId String
  studyId    String
  fieldId    String
  status     ConflictStatus @default(OPEN)
  openedAt   DateTime       @default(now())
  resolvedAt DateTime?

  template     ExtractionTemplate      @relation(fields: [templateId], references: [id])
  study        Study                   @relation(fields: [studyId], references: [id])
  field        ExtractionField         @relation(fields: [fieldId], references: [id])
  adjudication ExtractionAdjudication?

  @@unique([studyId, fieldId])
  @@index([templateId, status])
}

model ExtractionAdjudication {
  id            String   @id @default(cuid())
  conflictId    String   @unique
  adjudicatorId String
  finalValue    Json
  reason        String
  createdAt     DateTime @default(now())

  conflict    ExtractionConflict @relation(fields: [conflictId], references: [id])
  adjudicator User               @relation("ExtractionAdjudicator", fields: [adjudicatorId], references: [id])
}

// ---------------------------------------------------------------------------
// AI assistance (docs/01 extension seam: AI output lives in separate suggestion
// tables keyed to the same entities — human decision tables stay human-only)
// ---------------------------------------------------------------------------

model AiScreeningRun {
  id              String      @id @default(cuid())
  projectId       String
  stageId         String
  status          AiRunStatus @default(PENDING)
  provider        String // "anthropic" | "openai" | "gemini"
  model           String
  promptVersion   String
  providerBatchId String?
  requestKeys     Json? // citationIds in submission order — maps positional batch results (gemini inline)
  totalCount      Int         @default(0)
  succeededCount  Int         @default(0)
  failedCount     Int         @default(0)
  error           String?
  usage           Json? // { inputTokens, outputTokens } aggregated over batch items
  requestedById   String
  createdAt       DateTime    @default(now())
  submittedAt     DateTime?
  completedAt     DateTime?

  project     Project               @relation(fields: [projectId], references: [id])
  stage       ScreeningStage        @relation(fields: [stageId], references: [id])
  requestedBy User                  @relation("AiScreeningRunRequester", fields: [requestedById], references: [id])
  suggestions ScreeningSuggestion[]

  @@index([stageId, createdAt(sort: Desc)])
  @@index([projectId, status])
}

// Latest AI likelihood-of-inclusion suggestion per (stage, citation); re-runs replace.
// Never read by decision/conflict/PRISMA logic — display + queue ordering only.
model ScreeningSuggestion {
  id                String   @id @default(cuid())
  stageId           String
  citationId        String
  runId             String
  score             Int // 0–100 likelihood of inclusion, clamped on ingest
  suggestedDecision Decision // INCLUDE | EXCLUDE | MAYBE (UNRESOLVED never written)
  rationale         String
  provider          String // denormalized from run (docs/01: model/version live on the row)
  model             String
  promptVersion     String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  stage    ScreeningStage @relation(fields: [stageId], references: [id])
  citation Citation       @relation(fields: [citationId], references: [id])
  run      AiScreeningRun @relation(fields: [runId], references: [id])

  @@unique([stageId, citationId])
  @@index([runId])
  @@index([stageId, score])
}

model AiExtractionRun {
  id             String      @id @default(cuid())
  projectId      String
  studyId        String
  templateId     String
  fileId         String // the FullTextFile that was read
  status         AiRunStatus @default(PENDING)
  provider       String
  model          String
  promptVersion  String
  totalFields    Int         @default(0)
  suggestedCount Int         @default(0) // valid suggestions stored
  invalidCount   Int         @default(0) // returned but failed validateFieldValue
  notFoundCount  Int         @default(0)
  error          String?
  usage          Json?
  requestedById  String
  createdAt      DateTime    @default(now())
  completedAt    DateTime?

  project     Project                @relation(fields: [projectId], references: [id])
  study       Study                  @relation(fields: [studyId], references: [id])
  template    ExtractionTemplate     @relation(fields: [templateId], references: [id])
  file        FullTextFile           @relation(fields: [fileId], references: [id])
  requestedBy User                   @relation("AiExtractionRunRequester", fields: [requestedById], references: [id])
  suggestions ExtractionSuggestion[]

  @@index([studyId, templateId, createdAt(sort: Desc)])
  @@index([projectId, status])
}

// Latest AI value suggestion per (template, study, field); re-runs replace. Applying copies
// the value into the extractor's own ExtractionValue via upsertValue — the human stays the
// author; nothing ever writes an ExtractionValue directly from AI output.
model ExtractionSuggestion {
  id            String   @id @default(cuid())
  runId         String
  templateId    String
  studyId       String
  fieldId       String
  value         Json? // null when notFound or invalid-and-unstorable
  sourceQuote   String?
  pageNumber    Int?
  sourceAnchor  Json? // { fileId, page } — copied onto ExtractionValue.sourceAnchor on apply
  confidence    Float? // 0–1, clamped on ingest
  notFound      Boolean  @default(false)
  invalidReason String? // set when the model's value failed validateFieldValue; never applyable
  provider      String
  model         String
  promptVersion String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  run      AiExtractionRun    @relation(fields: [runId], references: [id])
  template ExtractionTemplate @relation(fields: [templateId], references: [id])
  study    Study              @relation(fields: [studyId], references: [id])
  field    ExtractionField    @relation(fields: [fieldId], references: [id])

  @@unique([templateId, studyId, fieldId])
  @@index([runId])
  @@index([studyId])
}

// ---------------------------------------------------------------------------
// Analysis (meta-analysis module) — consumes extraction data READ-ONLY via the
// value resolver (adjudicated > consensus > single); never writes extraction tables.
// ---------------------------------------------------------------------------

// A meta-analyzable outcome: which effect measure to compute and (via mappings) which
// extraction fields carry the numbers. Optionally anchored to a protocol OutcomeDefinition.
model AnalysisOutcome {
  id                  String              @id @default(cuid())
  projectId           String
  outcomeDefinitionId String? // optional protocol anchor (R9-validated)
  name                String
  timepoint           String?
  measure             EffectMeasure
  direction           EffectDirection     @default(LOWER_IS_BETTER)
  model               PoolingModel        @default(RANDOM) // display default; both always computed
  proportionTransform ProportionTransform @default(LOGIT) // used when measure = PROPORTION (phase B)
  groupLabels         Json? // { g1: "Intervention", g2: "Control" }
  order               Int                 @default(0)
  createdById         String
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  project           Project            @relation(fields: [projectId], references: [id])
  outcomeDefinition OutcomeDefinition? @relation(fields: [outcomeDefinitionId], references: [id])
  createdBy         User               @relation("AnalysisOutcomeCreator", fields: [createdById], references: [id])

  mappings         AnalysisFieldMap[]
  exclusions       AnalysisStudyExclusion[]
  gradeAssessment  GradeAssessment?
  aiGradeRuns      AiGradeRun[]
  gradeSuggestions GradeDomainSuggestion[]

  @@index([projectId, order])
}

// Maps one AnalysisRole to an extraction field. Stores the templateId the user mapped
// against plus the stable fieldKey; the resolver expands the template's version lineage
// (sourceTemplateId walk) so mappings survive template versioning.
model AnalysisFieldMap {
  id                String       @id @default(cuid())
  analysisOutcomeId String
  role              AnalysisRole
  templateId        String
  fieldKey          String

  outcome  AnalysisOutcome    @relation(fields: [analysisOutcomeId], references: [id])
  template ExtractionTemplate @relation(fields: [templateId], references: [id])

  @@unique([analysisOutcomeId, role])
}

// Manual per-outcome study exclusion (sensitivity valve) — audited.
model AnalysisStudyExclusion {
  id                String   @id @default(cuid())
  analysisOutcomeId String
  studyId           String
  reason            String
  createdById       String
  createdAt         DateTime @default(now())

  outcome   AnalysisOutcome @relation(fields: [analysisOutcomeId], references: [id])
  study     Study           @relation(fields: [studyId], references: [id])
  createdBy User            @relation("AnalysisExclusionCreator", fields: [createdById], references: [id])

  @@unique([analysisOutcomeId, studyId])
}

// --- GRADE (certainty of evidence, phase C) --------------------------------

enum GradeDomain {
  RISK_OF_BIAS
  INCONSISTENCY
  INDIRECTNESS
  IMPRECISION
  PUBLICATION_BIAS
}

enum GradeJudgment {
  NOT_SERIOUS
  SERIOUS
  VERY_SERIOUS
}

enum GradeCertainty {
  HIGH
  MODERATE
  LOW
  VERY_LOW
}

enum GradeAssessmentStatus {
  DRAFT
  REVIEWED // any subsequent edit flips back to DRAFT (service-enforced)
}

enum GradeStartingLevel {
  HIGH // randomized evidence — certainty arithmetic starts at 4 points
  LOW // non-randomized/observational — starts at 2 points
}

enum GradeRatingOrigin {
  AUTO // deterministic tier-1 draft (no AI, pure rules over pooled results)
  HUMAN // manually set or edited by a person
  AI_APPLIED // AI prose suggestion applied by a person
}

// One assessment per analysis outcome. `certainty` is stored (recomputed in the same tx as
// every rating/starting-level change) so SoF/export reads are cheap and consistent.
model GradeAssessment {
  id                String                @id @default(cuid())
  analysisOutcomeId String                @unique
  status            GradeAssessmentStatus @default(DRAFT)
  startingLevel     GradeStartingLevel    @default(HIGH)
  certainty         GradeCertainty
  generatedAt       DateTime // when the deterministic draft last (re)ran
  sourceFingerprint String? // canonical final-only statistics + RoB + outcome/protocol context
  reviewedById      String?
  reviewedAt        DateTime?
  createdById       String
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  outcome    AnalysisOutcome     @relation(fields: [analysisOutcomeId], references: [id])
  reviewedBy User?               @relation("GradeReviewer", fields: [reviewedById], references: [id])
  createdBy  User                @relation("GradeAssessmentCreator", fields: [createdById], references: [id])
  ratings    GradeDomainRating[]
}

// `metrics` snapshots the numbers the auto rule used (rounded, JSON-safe) so the UI can
// show provenance and detect staleness against a live recompute. Regeneration replaces
// only origin=AUTO ratings; HUMAN/AI_APPLIED ratings are preserved.
model GradeDomainRating {
  id             String            @id @default(cuid())
  assessmentId   String
  domain         GradeDomain
  judgment       GradeJudgment
  rationale      String
  origin         GradeRatingOrigin @default(AUTO)
  requiresReview Boolean           @default(false) // auto-draft marks irreducibly-human domains
  metrics        Json?
  updatedById    String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  assessment GradeAssessment @relation(fields: [assessmentId], references: [id])
  updatedBy  User?           @relation("GradeRatingEditor", fields: [updatedById], references: [id])

  @@unique([assessmentId, domain])
}

// One synchronous text-only structured call per outcome drafts per-domain prose (no PDF —
// inputs are the deterministic metrics + protocol PICO). Sync run: PENDING → COMPLETED|FAILED.
model AiGradeRun {
  id                String      @id @default(cuid())
  projectId         String
  analysisOutcomeId String
  status            AiRunStatus @default(PENDING)
  provider          String
  model             String
  promptVersion     String
  totalDomains      Int         @default(0)
  suggestedCount    Int         @default(0)
  invalidCount      Int         @default(0)
  error             String?
  usage             Json?
  requestedById     String
  createdAt         DateTime    @default(now())
  completedAt       DateTime?

  project     Project                 @relation(fields: [projectId], references: [id])
  outcome     AnalysisOutcome         @relation(fields: [analysisOutcomeId], references: [id])
  requestedBy User                    @relation("AiGradeRunRequester", fields: [requestedById], references: [id])
  suggestions GradeDomainSuggestion[]

  @@index([analysisOutcomeId, createdAt(sort: Desc)])
  @@index([projectId, status])
}

// Latest-wins full replace per outcome (deleteMany + createMany in the ingest tx). Display +
// apply-source only — never read by the certainty computation; a human applies a suggestion
// through updateDomainRating, which is the audited event (suggestion rows are unaudited).
model GradeDomainSuggestion {
  id                String        @id @default(cuid())
  runId             String
  analysisOutcomeId String
  domain            GradeDomain
  suggestedJudgment GradeJudgment
  rationale         String
  confidence        Float?
  provider          String
  model             String
  promptVersion     String
  createdAt         DateTime      @default(now())

  run     AiGradeRun      @relation(fields: [runId], references: [id])
  outcome AnalysisOutcome @relation(fields: [analysisOutcomeId], references: [id])

  @@unique([analysisOutcomeId, domain])
  @@index([runId])
}

// One synchronous provider call per (study, tool) reads the study's linked PDF and drafts,
// per domain: signaling answers, a judgment, and supporting verbatim quotes with pages.
model AiRobRun {
  id             String      @id @default(cuid())
  projectId      String
  studyId        String
  toolId         String
  fileId         String // the FullTextFile that was read
  status         AiRunStatus @default(PENDING)
  provider       String
  model          String
  promptVersion  String
  totalDomains   Int         @default(0)
  suggestedCount Int         @default(0) // applyable domain suggestions stored
  invalidCount   Int         @default(0) // judgment failed the tool's scale validation
  notFoundCount  Int         @default(0) // domain not assessable from the document
  error          String?
  usage          Json?
  requestedById  String
  createdAt      DateTime    @default(now())
  completedAt    DateTime?

  project     Project         @relation(fields: [projectId], references: [id])
  study       Study           @relation(fields: [studyId], references: [id])
  tool        RiskOfBiasTool  @relation(fields: [toolId], references: [id])
  file        FullTextFile    @relation(fields: [fileId], references: [id])
  requestedBy User            @relation("AiRobRunRequester", fields: [requestedById], references: [id])
  suggestions RobSuggestion[]

  @@index([studyId, toolId, createdAt(sort: Desc)])
  @@index([projectId, status])
}

// Latest AI draft per (tool, study, domain); re-runs replace. Never read by conflict,
// completion, or adjudication logic — display + apply-source only. Applying goes through
// the rob service's applySuggestion (human write path); the AI never writes a judgment or
// signaling-response row itself. NOTE: like extraction suggestions, these are shared across
// dual assessors — a deliberate, documented independence tradeoff.
model RobSuggestion {
  id                String   @id @default(cuid())
  runId             String
  toolId            String
  studyId           String
  domainId          String
  suggestedJudgment String? // validated against tool.judgmentScale on ingest; raw kept + invalidReason when it fails
  rationale         String // narrative draft for the "support for judgment" field
  quotes            Json // [{ text, page }] — verbatim, 1-based PDF pages
  signalingAnswers  Json // [{ questionId, answer, quote?, page?, invalidReason? }]
  confidence        Float? // 0–1, clamped on ingest
  notFound          Boolean  @default(false) // domain not assessable from the document
  invalidReason     String? // judgment failed scale validation; never applyable
  provider          String
  model             String
  promptVersion     String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  run    AiRobRun         @relation(fields: [runId], references: [id])
  tool   RiskOfBiasTool   @relation(fields: [toolId], references: [id])
  study  Study            @relation(fields: [studyId], references: [id])
  domain RiskOfBiasDomain @relation(fields: [domainId], references: [id])

  @@unique([toolId, studyId, domainId])
  @@index([runId])
  @@index([studyId])
}

// ---------------------------------------------------------------------------
// Risk of bias
// ---------------------------------------------------------------------------

// Built-in tools have projectId = null (seeded); custom tools are project-scoped.
model RiskOfBiasTool {
  id            String         @id @default(cuid())
  projectId     String?
  name          String
  description   String?
  isBuiltin     Boolean        @default(false)
  judgmentScale Json // allowed judgment values + labels/colors
  status        TemplateStatus @default(DRAFT)
  createdById   String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  project   Project? @relation(fields: [projectId], references: [id])
  createdBy User?    @relation("RobToolCreator", fields: [createdById], references: [id])

  domains       RiskOfBiasDomain[]
  assignments   RiskOfBiasAssignment[]
  assessments   RiskOfBiasAssessment[]
  conflicts     RiskOfBiasConflict[]
  protocols     Protocol[]
  aiRuns        AiRobRun[]
  aiSuggestions RobSuggestion[]

  @@index([projectId])
}

// Dual assessment is orchestrated: admins assign assessors per study (mirrors extraction).
model RiskOfBiasAssignment {
  id         String           @id @default(cuid())
  toolId     String
  studyId    String
  assessorId String
  status     AssignmentStatus @default(PENDING)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  tool     RiskOfBiasTool @relation(fields: [toolId], references: [id])
  study    Study          @relation(fields: [studyId], references: [id])
  assessor User           @relation("RobAssignee", fields: [assessorId], references: [id])

  @@unique([toolId, studyId, assessorId])
  @@index([assessorId, status])
}

model RiskOfBiasDomain {
  id       String  @id @default(cuid())
  toolId   String
  name     String
  guidance String?
  order    Int     @default(0)

  tool          RiskOfBiasTool                @relation(fields: [toolId], references: [id])
  questions     RiskOfBiasSignalingQuestion[]
  judgments     RiskOfBiasJudgment[]
  conflicts     RiskOfBiasConflict[]
  aiSuggestions RobSuggestion[]

  @@index([toolId, order])
}

model RiskOfBiasSignalingQuestion {
  id             String  @id @default(cuid())
  domainId       String
  text           String
  guidance       String?
  order          Int     @default(0)
  allowedAnswers Json // default ["Y","PY","PN","N","NI"]

  domain    RiskOfBiasDomain              @relation(fields: [domainId], references: [id])
  responses RiskOfBiasSignalingResponse[]

  @@index([domainId, order])
}

model RiskOfBiasAssessment {
  id              String     @id @default(cuid())
  toolId          String
  studyId         String
  assessorId      String
  status          FormStatus @default(IN_PROGRESS)
  overallJudgment String? // validated against tool.judgmentScale
  completedAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  tool      RiskOfBiasTool                @relation(fields: [toolId], references: [id])
  study     Study                         @relation(fields: [studyId], references: [id])
  assessor  User                          @relation("RobAssessor", fields: [assessorId], references: [id])
  judgments RiskOfBiasJudgment[]
  responses RiskOfBiasSignalingResponse[]

  @@unique([toolId, studyId, assessorId])
  @@index([studyId])
}

model RiskOfBiasJudgment {
  id           String   @id @default(cuid())
  assessmentId String
  domainId     String
  judgment     String // validated against tool.judgmentScale
  support      String? // "support for judgment" free text
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assessment RiskOfBiasAssessment @relation(fields: [assessmentId], references: [id])
  domain     RiskOfBiasDomain     @relation(fields: [domainId], references: [id])

  @@unique([assessmentId, domainId])
}

model RiskOfBiasSignalingResponse {
  id           String  @id @default(cuid())
  assessmentId String
  questionId   String
  answer       String
  note         String?

  assessment RiskOfBiasAssessment        @relation(fields: [assessmentId], references: [id])
  question   RiskOfBiasSignalingQuestion @relation(fields: [questionId], references: [id])

  @@unique([assessmentId, questionId])
}

// domainId null = conflict on the OVERALL judgment (uniqueness of the overall conflict per
// study+tool is service-enforced inside the detection transaction; Postgres treats NULLs as
// distinct in unique indexes).
model RiskOfBiasConflict {
  id         String         @id @default(cuid())
  toolId     String
  studyId    String
  domainId   String?
  status     ConflictStatus @default(OPEN)
  openedAt   DateTime       @default(now())
  resolvedAt DateTime?

  tool         RiskOfBiasTool          @relation(fields: [toolId], references: [id])
  study        Study                   @relation(fields: [studyId], references: [id])
  domain       RiskOfBiasDomain?       @relation(fields: [domainId], references: [id])
  adjudication RiskOfBiasAdjudication?

  @@unique([studyId, domainId])
  @@index([toolId, status])
}

model RiskOfBiasAdjudication {
  id            String   @id @default(cuid())
  conflictId    String   @unique
  adjudicatorId String
  finalJudgment String // validated against tool.judgmentScale
  reason        String
  createdAt     DateTime @default(now())

  conflict    RiskOfBiasConflict @relation(fields: [conflictId], references: [id])
  adjudicator User               @relation("RobAdjudicator", fields: [adjudicatorId], references: [id])
}

// ---------------------------------------------------------------------------
// PRISMA reporting
// ---------------------------------------------------------------------------

// Counts are computed live by the service; snapshots freeze them for reporting.
model PrismaSnapshot {
  id          String   @id @default(cuid())
  projectId   String
  label       String
  data        Json // full structured snapshot (PRISMA 2020 shape)
  createdById String
  createdAt   DateTime @default(now())

  project   Project       @relation(fields: [projectId], references: [id])
  createdBy User          @relation("SnapshotCreator", fields: [createdById], references: [id])
  counts    PrismaCount[]

  @@index([projectId])
}

model PrismaCount {
  id         String @id @default(cuid())
  snapshotId String
  key        String // e.g. "records_identified", "reports_excluded"
  label      String
  value      Int
  breakdown  Json? // per-source / per-reason detail (spec: FullTextExclusionSummary)

  snapshot PrismaSnapshot @relation(fields: [snapshotId], references: [id])

  @@unique([snapshotId, key])
}

// ---------------------------------------------------------------------------
// Audit trail (append-only; see docs/06-audit-design.md)
// ---------------------------------------------------------------------------

model AuditEvent {
  id            String   @id @default(cuid())
  projectId     String?
  userId        String
  entityType    String
  entityId      String
  action        String
  previousValue Json?
  newValue      Json?
  reason        String?
  metadata      Json?
  createdAt     DateTime @default(now())

  project Project? @relation(fields: [projectId], references: [id])
  user    User     @relation("AuditActor", fields: [userId], references: [id])

  @@index([projectId, createdAt(sort: Desc)])
  @@index([entityType, entityId])
  @@index([projectId, userId])
  @@index([projectId, action])
}

// ---------------------------------------------------------------------------
// Exports
// ---------------------------------------------------------------------------

model ExportJob {
  id            String       @id @default(cuid())
  projectId     String
  kind          ExportKind
  format        ExportFormat
  status        ExportStatus @default(PENDING)
  storageKey    String?
  error         String?
  requestedById String
  createdAt     DateTime     @default(now())
  completedAt   DateTime?

  project     Project @relation(fields: [projectId], references: [id])
  requestedBy User    @relation("ExportRequester", fields: [requestedById], references: [id])

  @@index([projectId])
}

// ---------------------------------------------------------------------------
// Reference library (citation manager for the manuscript)
// ---------------------------------------------------------------------------

// Project-scoped bibliography for the PAPER — methods papers, background refs, and
// mirrors of included studies. Distinct from Citation (the screening corpus): entries
// here are curated writing material, not evidence-trail records, so deletes are hard.
// `csl` (a CSL-JSON item) is the source of truth for formatting/export; the scalar
// columns are denormalized for search and dedupe.
model ReferenceEntry {
  id          String   @id @default(cuid())
  projectId   String
  csl         Json
  title       String
  firstAuthor String?
  year        Int?
  doi         String? // normalized: lowercase, no resolver prefix
  pmid        String? // normalized: digits only
  tags        String[]
  notes       String?
  citationId  String? // set when this entry mirrors a screening Citation
  addedById   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project  Project   @relation(fields: [projectId], references: [id])
  citation Citation? @relation(fields: [citationId], references: [id])
  addedBy  User      @relation("ReferenceAdder", fields: [addedById], references: [id])

  @@unique([projectId, doi]) // Postgres: NULL dois unconstrained
  @@unique([projectId, citationId]) // a screening citation mirrors at most once
  @@index([projectId, title])
  @@index([projectId, createdAt])
}

// ---------------------------------------------------------------------------
// Manuscript drafting (modular sections, locks + versions, comments)
// ---------------------------------------------------------------------------

enum ManuscriptSectionKind {
  TITLE_PAGE
  ABSTRACT
  INTRODUCTION
  METHODS
  RESULTS
  DISCUSSION
  CONCLUSION
  ACKNOWLEDGMENTS
  CUSTOM
}

enum ManuscriptSectionStatus {
  DRAFT
  IN_REVIEW
  APPROVED
}

enum ManuscriptVersionOrigin {
  EXPLICIT // "Save version" button (note allowed)
  LOCK_RELEASE // cut automatically when an editing session ends with unsaved-to-version changes
  TAKEOVER // pre-image cut on stale-lock takeover, attributed to the previous holder
  RESTORE // pre-image cut immediately before a restore
}

enum ManuscriptCommentStatus {
  OPEN
  RESOLVED
}

// One default manuscript per project (v1); drop the unique to allow multiple later.
model Manuscript {
  id              String   @id @default(cuid())
  projectId       String   @unique
  title           String   @default("Manuscript")
  citationStyleId String? // CSL style id (src/server/csl/engine.ts); null = default
  createdById     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project   Project             @relation(fields: [projectId], references: [id])
  createdBy User                @relation("ManuscriptCreator", fields: [createdById], references: [id])
  sections  ManuscriptSection[]
}

// Concurrency model: soft lock (one editor per section; heartbeat 30s, stale at 90s,
// takeover allowed when stale) + `version` optimistic-concurrency counter on content
// writes. Autosaves overwrite `content` in place (unaudited); durable snapshots live in
// ManuscriptSectionVersion, cut at session boundaries.
model ManuscriptSection {
  id              String                  @id @default(cuid())
  manuscriptId    String
  title           String
  kind            ManuscriptSectionKind   @default(CUSTOM)
  order           Int // 0-based; service rewrites 0..n-1 on reorder
  content         Json // TipTap doc JSON; initialized to {"type":"doc","content":[]}
  contentText     String                  @default("") // server-derived plain text
  wordCount       Int                     @default(0)
  status          ManuscriptSectionStatus @default(DRAFT)
  assigneeId      String? // assignee may edit this section even without manuscript.edit
  lockedById      String?
  lockAcquiredAt  DateTime?
  lockHeartbeatAt DateTime?
  version         Int                     @default(0) // ++ on every content write
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  manuscript Manuscript                 @relation(fields: [manuscriptId], references: [id])
  assignee   User?                      @relation("ManuscriptSectionAssignee", fields: [assigneeId], references: [id])
  lockedBy   User?                      @relation("ManuscriptSectionLockHolder", fields: [lockedById], references: [id])
  versions   ManuscriptSectionVersion[]
  comments   ManuscriptComment[]

  @@index([manuscriptId, order])
  @@index([assigneeId])
}

// Immutable snapshot rows (append-only, like ProtocolVersion).
model ManuscriptSectionVersion {
  id              String                  @id @default(cuid())
  sectionId       String
  versionNumber   Int // 1..n per section
  capturedVersion Int // ManuscriptSection.version at snapshot time — makes "cut if dirty" idempotent
  origin          ManuscriptVersionOrigin
  content         Json
  contentText     String
  wordCount       Int
  note            String?
  savedById       String // TAKEOVER rows are attributed to the PREVIOUS lock holder
  createdAt       DateTime                @default(now())

  section ManuscriptSection @relation(fields: [sectionId], references: [id])
  savedBy User              @relation("ManuscriptVersionAuthor", fields: [savedById], references: [id])

  @@unique([sectionId, versionNumber])
  @@index([sectionId])
}

model ManuscriptComment {
  id           String                  @id @default(cuid())
  sectionId    String
  authorId     String
  parentId     String? // one-level threads: parent must be a root comment in the same section
  body         String
  quotedText   String? // optional excerpt the comment refers to
  status       ManuscriptCommentStatus @default(OPEN)
  resolvedById String?
  resolvedAt   DateTime?
  mentions     String[] // user ids chosen in the composer; validated ⊆ ACTIVE project members
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  section    ManuscriptSection   @relation(fields: [sectionId], references: [id])
  author     User                @relation("ManuscriptCommentAuthor", fields: [authorId], references: [id])
  resolvedBy User?               @relation("ManuscriptCommentResolver", fields: [resolvedById], references: [id])
  parent     ManuscriptComment?  @relation("ManuscriptCommentThread", fields: [parentId], references: [id])
  replies    ManuscriptComment[] @relation("ManuscriptCommentThread")

  @@index([sectionId, status])
  @@index([parentId])
}

// ---------------------------------------------------------------------------
// Team chat (channels, DMs, threads, assignment messages)
// ---------------------------------------------------------------------------

enum ChatChannelKind {
  GENERAL // one per project, lazily created
  TOPIC // named, public to all active members
  DIRECT // fixed explicit participant set (1:1 and small groups)
}

enum ChatMessageKind {
  MESSAGE
  ASSIGNMENT // carries ChatAssignmentTask rows (per-assignee done-tracking)
}

model ChatChannel {
  id            String          @id @default(cuid())
  projectId     String
  kind          ChatChannelKind
  name          String? // TOPIC only
  // GENERAL: "general"; DIRECT: "dm:" + sorted participant userIds joined ":"; TOPIC:
  // null (Postgres treats NULLs as distinct). One unique gives race-safe lazy #general
  // creation AND direct-message dedupe by participant set.
  dedupeKey     String?
  archivedAt    DateTime? // TOPIC only (service-enforced); archived = read-only
  lastMessageAt DateTime? // denorm set in postMessage tx — channel-list sort without groupBy
  createdById   String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  project      Project                  @relation(fields: [projectId], references: [id])
  createdBy    User                     @relation("ChatChannelCreator", fields: [createdById], references: [id])
  participants ChatChannelParticipant[]
  messages     ChatMessage[]
  readStates   ChatReadState[]

  @@unique([projectId, dedupeKey])
  @@index([projectId, kind])
}

// DIRECT channels only. GENERAL/TOPIC membership is implicit (all ACTIVE project members).
model ChatChannelParticipant {
  id        String   @id @default(cuid())
  channelId String
  userId    String
  createdAt DateTime @default(now())

  channel ChatChannel @relation(fields: [channelId], references: [id])
  user    User        @relation("ChatParticipant", fields: [userId], references: [id])

  @@unique([channelId, userId])
  @@index([userId])
}

// AUDIT POLICY (deliberate deviation, docs/06): message post/edit and read-state upserts
// are NOT audited — chat is high-frequency conversational data and messages are their own
// durable attributed record (authorId/createdAt/editedAt/tombstones). Structural events
// (channel create/archive, assignment lifecycle, deletes) ARE audited.
model ChatMessage {
  id          String          @id @default(cuid())
  channelId   String
  authorId    String
  parentId    String? // ONE-level threads: parent must itself be a root (service-enforced)
  kind        ChatMessageKind @default(MESSAGE)
  body        String // plain text ≤8000; mention tokens @[Name](userId) + literal @channel
  mentions    String[] // userIds extracted + validated server-side (ACTIVE members only)
  replyCount  Int             @default(0) // non-deleted replies, maintained in the same tx
  editedAt    DateTime?
  deletedAt   DateTime? // soft delete — tombstone rendered, body withheld from payloads
  deletedById String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  channel         ChatChannel          @relation(fields: [channelId], references: [id])
  author          User                 @relation("ChatMessageAuthor", fields: [authorId], references: [id])
  deletedBy       User?                @relation("ChatMessageDeleter", fields: [deletedById], references: [id])
  parent          ChatMessage?         @relation("ChatThread", fields: [parentId], references: [id])
  replies         ChatMessage[]        @relation("ChatThread")
  assignmentTasks ChatAssignmentTask[]

  @@index([channelId, createdAt]) // history pagination + unread range counts
  @@index([channelId, updatedAt]) // incremental poll cursor (new + edited + tombstoned)
  @@index([parentId])
}

// One row per assignee of an ASSIGNMENT message — each assignee marks done independently.
// Mirrors ScreeningAssignment/ExtractionAssignment ([assigneeId, status] queue index).
model ChatAssignmentTask {
  id          String           @id @default(cuid())
  messageId   String
  projectId   String // denorm — "my assignments" without joining message→channel→project
  assigneeId  String
  dueAt       DateTime?
  status      AssignmentStatus @default(PENDING) // VOIDED when the message is deleted
  completedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  message  ChatMessage @relation(fields: [messageId], references: [id])
  project  Project     @relation(fields: [projectId], references: [id])
  assignee User        @relation("ChatAssignee", fields: [assigneeId], references: [id])

  @@unique([messageId, assigneeId])
  @@index([assigneeId, status])
  @@index([projectId, status])
}

model ChatReadState {
  id         String   @id @default(cuid())
  channelId  String
  userId     String
  lastReadAt DateTime // forward-only watermark (service clamps: max(existing, min(input, now)))
  updatedAt  DateTime @updatedAt

  channel ChatChannel @relation(fields: [channelId], references: [id])
  user    User        @relation("ChatReader", fields: [userId], references: [id])

  @@unique([channelId, userId])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// Notifications (in-app delivery substrate)
// ---------------------------------------------------------------------------

// `type` is a string validated against the NotificationTypes catalog in
// src/server/services/notifications/index.ts — not a Prisma enum, so features add
// types without a migration (same convention as AuditEvent.action). Rows are created
// by notifications.emit() INSIDE the emitting service's transaction, so a notification
// can never exist without its triggering domain row. Deliberately unaudited: a
// notification is a derived delivery artifact, not a domain mutation.
model Notification {
  id        String    @id @default(cuid())
  userId    String // recipient
  projectId String
  type      String
  actorId   String?
  payload   Json // entity ids + short snippet; enough to render the row + build its href
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user    User    @relation("NotificationRecipient", fields: [userId], references: [id])
  actor   User?   @relation("NotificationActor", fields: [actorId], references: [id])
  project Project @relation(fields: [projectId], references: [id])

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, readAt])
}
